<!-- pages/study/study.wxml -->
<view class="study">
  <!-- 顶部banner -->
  <image src="/images/study_banner.jpg" mode="widthFix" class="banner"></image>

  <!-- 课程列表 -->
  <view class="course-list">
    <view 
      class="course-card" 
      wx:for="{{courses}}" 
      wx:key="_id"
      bindtap="goToDetail"
      data-course="{{item}}"
    >
      <image src="{{item.image}}" mode="aspectFill"></image>
      <view class="info">
        <text class="name">{{item.name}}</text>
        <text class="desc">{{item.desc}}</text>
        <view class="bottom">
          <text class="price">¥{{item.price}}</text>
          <text class="students">已报 {{item.enrolled || 0}} 人</text>
          <button
            size="mini"
            type="warn"
            catchtap="signup"
            data-item="{{item}}"
          >立即预约</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:elif="{{courses.length === 0}}" class="empty">暂无课程，敬请期待~</view>
</view>
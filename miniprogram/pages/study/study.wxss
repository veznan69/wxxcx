.study {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
  padding-top: 0 !important; 
  margin-top: 0 !important;
}

.banner {
  width: 100%;
  display: block;
  height: auto; 
}

.course-list {
  padding: 20rpx;
  margin-top: 0; 
}

.course-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.course-card image {
  width: 100%;
  height: 430rpx; 
  display: block;
}

.course-card .info {
  padding: 20rpx;
}

.course-card .name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.course-card .desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 20rpx;
  display: block;
}

.course-card .bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.course-card .price {
  color: #ff6600;
  font-size: 36rpx;
  font-weight: bold;
}

.course-card .students {
  font-size: 24rpx;
  color: #999;
  flex: 1;
  margin-left: 20rpx;
}

.course-card button {
  background-color: #ff6600;
  color: #fff;
  font-size: 26rpx;
  width: 160rpx;
  height: 60rpx;
  line-height: 60rpx;
}

.loading, .empty {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}
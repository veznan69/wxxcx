.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: 40rpx;
}

.page-header {
  margin-bottom: 30rpx;
  margin-top: 20rpx;
}
.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a1a;
}
.stats {
  font-size: 26rpx;
  color: #888;
  margin-top: 8rpx;
}

/* 选项卡 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 40rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}
.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 34rpx;
  transition: all 0.2s;
}
.tab.active {
  background: #FF6600;
  color: #fff;
  font-weight: bold;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.03);
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.shop-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #222;
}
.status-tag {
  font-size: 24rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}
.status-pending {
  background: #fff7e6;
  color: #FF6600;
}
.status-approved {
  background: #e6f7e6;
  color: #07c160;
}
.status-rejected {
  background: #fee;
  color: #fa5151;
}

.info-row {
  display: flex;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  line-height: 1.5;
}
.label {
  width: 150rpx;
  color: #888;
}
.license-section {
  margin-top: 10rpx;
  margin-bottom: 16rpx;
}
.image-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
}
.license-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #eee;
}
.time-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #aaa;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}
.reject-reason {
  background: #fef0f0;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #d32f2f;
}
.actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 24rpx;
  gap: 20rpx;
}
.btn {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}
.btn-approve {
  background: #07c160;
  color: #fff;
}
.btn-reject {
  background: #fff;
  color: #fa5151;
  border: 1rpx solid #fa5151;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 150rpx;
}
.empty-text {
  color: #aaa;
  font-size: 30rpx;
}

/* 权限拦截层 */
.permission-deny {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.98);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.deny-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}
.deny-text {
  font-size: 32rpx;
  color: #555;
  margin-bottom: 50rpx;
}
.deny-btn {
  background: #FF6600;
  color: #fff;
  border-radius: 48rpx;
  padding: 20rpx 80rpx;
  font-size: 32rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 900;
}
.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  z-index: 901;
}
.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}
.modal-content textarea {
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 20rpx;
  width: 100%;
  height: 200rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}
.modal-btns {
  display: flex;
  margin-top: 30rpx;
  gap: 20rpx;
}
.cancel-btn, .confirm-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
}
.cancel-btn {
  background: #f5f5f5;
  color: #666;
}
.confirm-btn {
  background: #FF6600;
  color: #fff;
}
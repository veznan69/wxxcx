.container {
  min-height: 100vh;
  background: linear-gradient(145deg, #f8f9fc 0%, #eef1f6 100%);
  padding: 32rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 60rpx;
  margin-top: 40rpx;
}

.title {
  font-size: 52rpx;
  font-weight: bold;
  color: #1a1a1a;
  text-align: center;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
  text-align: center;
  margin-top: 12rpx;
}

.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(0,0,0,0.05);
  margin-bottom: 48rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 28rpx;
}

.code-input {
  background: #f5f7fa;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  font-size: 42rpx;
  font-weight: bold;
  text-align: center;
  letter-spacing: 16rpx;
  color: #FF6600;
  border: 2rpx solid transparent;
  transition: border 0.2s;
}

.code-input:focus {
  border-color: #FF6600;
  background: #fff;
}

.hint {
  font-size: 24rpx;
  color: #aaa;
  text-align: center;
  margin-top: 20rpx;
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.primary-btn {
  background: #FF6600;
  color: #fff;
  border-radius: 48rpx;
  font-size: 36rpx;
  font-weight: bold;
  padding: 28rpx 0;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(255,102,0,0.3);
  transition: all 0.2s;
}

.primary-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.secondary-btn {
  background: #fff;
  color: #FF6600;
  border-radius: 48rpx;
  font-size: 36rpx;
  font-weight: bold;
  padding: 28rpx 0;
  border: 2rpx solid #FF6600;
}

.history {
  margin-top: 60rpx;
}

.history-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.history-list {
  background: #fff;
  border-radius: 24rpx;
  padding: 8rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-code {
  font-family: monospace;
  font-size: 30rpx;
  font-weight: bold;
  color: #FF6600;
  width: 140rpx;
}

.history-type {
  flex: 1;
  font-size: 28rpx;
  color: #444;
}

.history-time {
  font-size: 24rpx;
  color: #aaa;
}

.permission-deny {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.98);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  z-index: 999;
}

.deny-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.deny-text {
  font-size: 32rpx;
  color: #555;
  text-align: center;
  margin-bottom: 60rpx;
}

.deny-btn {
  background: #FF6600;
  color: #fff;
  border-radius: 48rpx;
  padding: 24rpx 80rpx;
  font-size: 32rpx;
}
.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 20rpx;
  box-sizing: border-box;
}

.tips {
  background: #fff7e8;
  border: 1rpx solid #ffe2bd;
  border-radius: 16rpx;
  padding: 20rpx;
  color: #8a5600;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  color: #6f4300;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  color: #222;
  font-weight: 600;
  margin-bottom: 18rpx;
}

.field {
  margin-bottom: 18rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  color: #444;
  font-size: 25rpx;
  margin-bottom: 10rpx;
}

.hint {
  display: block;
  color: #999;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.input,
.picker {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 10rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  color: #222;
  background: #fff;
  font-size: 26rpx;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 10rpx;
  padding: 14rpx 18rpx;
  box-sizing: border-box;
  color: #222;
  background: #fff;
  font-size: 24rpx;
  line-height: 1.5;
}

.textarea.small {
  min-height: 120rpx;
}

.textarea.code {
  min-height: 260rpx;
  font-family: Consolas, Menlo, Monaco, monospace;
}

.two-col {
  display: flex;
  gap: 14rpx;
}

.col {
  flex: 1;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.readonly {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.value {
  color: #666;
  font-size: 24rpx;
  max-width: 65%;
  text-align: right;
  word-break: break-all;
}

.footer {
  position: sticky;
  bottom: 16rpx;
  padding-top: 6rpx;
}

.save-btn {
  background: #ff6600;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
}

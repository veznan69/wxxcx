/* pages/serviceChat/serviceChat.wxss */

.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #EDEDED;
}

/* 聊天头部 */
.chat-header {
  padding: 20rpx 30rpx;
  background-color: #FFFFFF;
  border-bottom: 1rpx solid #E5E5E5;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.chat-header-info {
  display: flex;
  align-items: center;
}

.chat-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.chat-title-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.chat-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  line-height: 44rpx;
  margin-bottom: 4rpx;
}

.chat-status {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  line-height: 34rpx;
}

.status-dot {
  margin-right: 8rpx;
  font-size: 20rpx;
}

.status-text {
  color: #4CAF50;
  margin-right: 12rpx;
  font-weight: 500;
}

.status-desc {
  color: #999999;
}

/* 消息列表 */
.message-list {
  flex: 1;
  overflow-y: auto;
  margin-top: 140rpx;
  margin-bottom: 120rpx;
  height: calc(100vh - 260rpx);
}

/* 消息内容区 */
.message-content {
  padding: 20rpx 30rpx;
}

/* 消息项 */
.message-item {
  margin-bottom: 30rpx;
}

.message-row {
  display: flex;
  align-items: flex-start;
}

.message-row-left {
  flex-direction: row;
}

.message-row-right {
  flex-direction: row-reverse;
}

/* 消息头像 */
.message-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.message-row-left .message-avatar {
  margin-right: 20rpx;
}

.message-row-right .message-avatar {
  margin-left: 20rpx;
}

/* 消息内容容器 */
.message-content-wrapper {
  max-width: 70%;
}

.message-row-left .message-content-wrapper {
  margin-left: 0;
}

.message-row-right .message-content-wrapper {
  margin-right: 0;
  display: flex;
  justify-content: flex-end;
}

/* AI名称 */
.ai-name {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
  margin-left: 20rpx;
}

/* 消息气泡 */
.message-bubble {
  padding: 20rpx 24rpx;
  border-radius: 8rpx;
  position: relative;
  word-break: break-all;
}

.message-text {
  font-size: 30rpx;
  line-height: 42rpx;
  white-space: pre-wrap;
  color: #333333;
}

/* 对方气泡（白色） */
.other-bubble {
  background-color: #FFFFFF;
  border: 1rpx solid #E5E5E5;
}

.message-row-left .message-bubble {
  margin-left: 20rpx;
  border-radius: 8rpx;
  border-top-left-radius: 4rpx;
}

/* AI气泡（橙色渐变） */
.ai-bubble {
  background: linear-gradient(135deg, #FF6600 0%, #FF8533 100%);
  border: none;
}

.ai-bubble .message-text {
  color: #FFFFFF;
}

/* 自己气泡（橙色） */
.self-bubble {
  background: linear-gradient(135deg, #FF6600 0%, #FF8533 100%);
  border: none;
}

.message-row-right .message-bubble {
  margin-right: 20rpx;
  border-radius: 8rpx;
  border-top-right-radius: 4rpx;
}

.self-bubble .message-text {
  color: #FFFFFF;
}

/* 时间显示 */
.message-time {
  text-align: center;
  margin: 20rpx 0;
}

.message-time text {
  font-size: 24rpx;
  color: #999999;
  background-color: rgba(0, 0, 0, 0.05);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

/* 正在输入动画 */
.typing-bubble {
  background: linear-gradient(135deg, #FF6600 0%, #FF8533 100%);
  padding: 24rpx 32rpx;
  min-width: 120rpx;
}

.typing-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #FFFFFF;
  border-radius: 50%;
  animation: typing 1.4s infinite;
}

.typing-dot:nth-child(1) {
  animation-delay: 0s;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.4;
  }
  30% {
    transform: translateY(-10rpx);
    opacity: 1;
  }
}

/* 加载更多 */
.loading-more {
  text-align: center;
  padding: 30rpx 0;
}

.loading-more text {
  font-size: 26rpx;
  color: #999999;
}

/* 底部占位 */
.bottom-placeholder {
  height: 20rpx;
}

/* 底部输入框 */
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #F7F7F7;
  border-top: 1rpx solid #E5E5E5;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 99;
}

.input-container {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
}

/* 输入框 */
.message-input {
  flex: 1;
  margin: 0 20rpx;
  font-size: 30rpx;
  height: 60rpx;
  line-height: 60rpx;
}

.message-input::placeholder {
  color: #CCCCCC;
}

/* 发送按钮 */
.send-btn {
  min-width: 120rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #FF6600 0%, #FF8533 100%);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  flex-shrink: 0;
}

.send-btn text {
  font-size: 28rpx;
  color: #FFFFFF;
  line-height: 1;
}

.send-btn.disabled {
  background: #E5E5E5;
}

.send-btn.disabled text {
  color: #999999;
}

/* pages/serviceChat/serviceChat.wxss */

.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 20rpx 0;
  overflow-y: auto;
}

/* 消息项 */
.message-item {
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
}

.message-wrapper {
  display: flex;
  align-items: flex-start;
  max-width: 80%;
}

/* 对方消息（左对齐） */
.other-wrapper {
  flex-direction: row;
  align-self: flex-start;
}

.other-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #e0e0e0;
}

.other-bubble {
  background-color: #ffffff;
  border-radius: 12rpx;
  border-top-left-radius: 4rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 自己的消息（右对齐） */
.self-wrapper {
  flex-direction: row-reverse;
  align-self: flex-end;
}

.self-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
  background-color: #ff6600;
}

.self-bubble {
  background: linear-gradient(135deg, #ff6600 0%, #ff8533 100%);
  border-radius: 12rpx;
  border-top-right-radius: 4rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 102, 0, 0.2);
}

/* 消息文本 */
.message-text {
  font-size: 28rpx;
  line-height: 40rpx;
  word-break: break-all;
  white-space: pre-wrap;
}

.other-bubble .message-text {
  color: #333333;
}

.self-bubble .message-text {
  color: #ffffff;
}

/* 时间显示 */
.message-time {
  align-self: center;
  margin: 10rpx 0;
}

.message-time text {
  font-size: 22rpx;
  color: #999999;
  background-color: rgba(0, 0, 0, 0.05);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 加载更多 */
.loading-more {
  text-align: center;
  padding: 20rpx 0;
}

.loading-more text {
  font-size: 24rpx;
  color: #999999;
}

/* 底部占位 */
.bottom-placeholder {
  height: 20rpx;
}

/* 底部输入框 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.message-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  margin-right: 20rpx;
}

.message-input::placeholder {
  color: #999999;
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0;
  font-size: 28rpx;
  background: linear-gradient(135deg, #ff6600 0%, #ff8533 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
}

.send-btn.disabled {
  background: #cccccc;
  color: #999999;
}

.send-btn::after {
  border: none;
}

<view class="chat-container">
  <!-- 聊天头部 -->
  <view class="chat-header">
    <view class="chat-header-info">
      <image class="chat-avatar" src="/images/icons/avatar.png" mode="aspectFill"></image>
      <view class="chat-title-group">
        <text class="chat-title">橙小妹</text>
        <view class="chat-status">
          <text class="status-dot">🟢</text>
          <text class="status-text">在线</text>
          <text class="status-desc">AI智能客服</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="message-list"
    scroll-y
    scroll-into-view="{{toView}}"
    scroll-with-animation
    scroll-top="{{scrollTop}}"
  bindtap="onMessageListTap"      
  >
    <view class="message-content">
      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="msg-{{item.id}}"
        class="message-item {{item.isSelf ? 'message-right' : 'message-left'}}"
      >
        <!-- 时间显示 -->
        <view wx:if="{{item.showTime}}" class="message-time">
          <text>{{item.timeStr}}</text>
        </view>

        <!-- 对方消息 -->
        <view wx:if="{{!item.isSelf}}" class="message-row message-row-left">
          <image
            class="message-avatar"
            src="/images/icons/avatar.png"
            mode="aspectFill"
          ></image>
          <view class="message-content-wrapper">
            <view wx:if="{{item.isAI}}" class="ai-name">橙小妹</view>
            <view class="message-bubble {{item.isAI ? 'ai-bubble' : 'other-bubble'}}">
              <text class="message-text">{{item.content}}</text>
            </view>
          </view>
        </view>

        <!-- 自己的消息 -->
        <view wx:if="{{item.isSelf}}" class="message-row message-row-right">
          <view class="message-content-wrapper">
            <view class="message-bubble self-bubble">
              <text class="message-text">{{item.content}}</text>
            </view>
          </view>
          <image
            class="message-avatar self-avatar"
            src="/images/icons/avatar.png"
            mode="aspectFill"
          ></image>
        </view>

        <!-- 正在输入动画 -->
        <view wx:if="{{item.isTyping}}" class="message-row message-row-left">
          <image
            class="message-avatar"
            src="/images/icons/avatar.png"
            mode="aspectFill"
          ></image>
          <view class="message-content-wrapper">
            <view class="ai-name">橙小妹</view>
            <view class="message-bubble typing-bubble">
              <view class="typing-dots">
                <view class="typing-dot"></view>
                <view class="typing-dot"></view>
                <view class="typing-dot"></view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多提示 -->
    <view wx:if="{{loading}}" class="loading-more">
      <text>加载中...</text>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </scroll-view>

  <!-- 底部输入框 -->
  <view class="input-bar" style="bottom: {{keyboardHeight}}px">
    <view class="input-container">
      <input
        class="message-input"
        value="{{inputText}}"
        bindinput="onInput"
        bindkeyboardheightchange="onKeyboardHeightChange"
        bindblur="onInputBlur"           
        placeholder="输入消息..."
        confirm-type="send"
        bindconfirm="sendMessage"
        maxlength="500"
        cursor-spacing="10"
        adjust-position="{{false}}"
      />

      <view
        class="send-btn {{!inputText ? 'disabled' : ''}}"
        bindtap="sendMessage"
      >
        <text>发送</text>
      </view>
    </view>
  </view>
</view>

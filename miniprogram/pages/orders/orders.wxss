/* pages/orders/orders.wxss */
.tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
}
.tab-item.active {
  color: #FF6600;
  border-bottom: 4rpx solid #FF6600;
}
.order-list {
  padding: 20rpx;
}
.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.order-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}
.order-status {
  color: #FF6600;
}
.order-time {
  color: #999;
}
.goods-item {
  display: flex;
  margin-bottom: 20rpx;
}
.goods-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}
.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.goods-name {
  font-size: 28rpx;
  color: #333;
}
.goods-price {
  font-size: 26rpx;
  color: #FF6600;
}
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}
.total {
  font-size: 28rpx;
  color: #333;
}

.logistics-btn {
  margin: 0;
  background: #f5f5f5;
  color: #555;
  font-size: 24rpx;
  border-radius: 999rpx;
  padding: 0 24rpx;
}

.actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.received-btn {
  margin: 0;
  background: #ffefe4;
  color: #ff6600;
  font-size: 24rpx;
  border-radius: 999rpx;
  padding: 0 24rpx;
}
.pay-btn {
  background: #FF6600;
  color: #fff;
  font-size: 26rpx;
  padding: 10rpx 30rpx;
  border-radius: 40rpx;
  margin: 0;
}
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

/* pages/orders/orders.wxss */
.orders-page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.search-box {
  background-color: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 5;
}

.search-box icon {
  margin-right: 15rpx;
}

.search-box input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.clear-btn {
  font-size: 32rpx;
  color: #999;
  padding: 0 10rpx;
}

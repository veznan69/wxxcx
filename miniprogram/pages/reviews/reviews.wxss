.reviews {
  background: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}
.publish-btn {
  margin-bottom: 20rpx;
  text-align: right;
}
.review-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
}
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}
.content {
  flex: 1;
}
.nickname {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}
.images {
  display: flex;
  flex-wrap: wrap;
  margin-top: 10rpx;
}
.images image {
  width: 200rpx;
  height: 200rpx;
  margin-right: 10rpx;
  border-radius: 12rpx;
}
.time {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
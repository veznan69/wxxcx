<view class="cart-page">
  <scroll-view
    wx:if="{{cartItems.length > 0}}"
    class="cart-list"
    scroll-y="true"
    enhanced="true"
    show-scrollbar="false"
  >
    <view class="cart-item" wx:for="{{cartItems}}" wx:key="id">
      <checkbox
        class="item-checkbox"
        value="{{item.id}}"
        checked="{{item.checked}}"
        bindtap="toggleCheck"
        data-id="{{item.id}}"
        data-goods-id="{{item.goodsId}}"
        data-sku-id="{{item.skuId}}"
        color="#ff6600"
      />
      <image class="item-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-price">￥{{item.price}}</text>
        <view class="item-stepper">
          <view class="stepper-btn minus" bindtap="subNum" data-id="{{item.id}}" data-goods-id="{{item.goodsId}}" data-sku-id="{{item.skuId}}">-</view>
          <text class="stepper-num">{{item.num}}</text>
          <view class="stepper-btn plus" bindtap="addNum" data-id="{{item.id}}" data-goods-id="{{item.goodsId}}" data-sku-id="{{item.skuId}}">+</view>
        </view>
      </view>
    </view>
    <view class="cart-list-bottom-space"></view>
  </scroll-view>

  <view wx:else class="empty-cart">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车空空如也</text>
    <button class="go-shop-btn" open-type="switchTab" url="/pages/goods/goods" bindtap="goToShop">去逛逛</button>
  </view>

  <view class="settlement-bar" wx:if="{{cartItems.length > 0}}">
    <view class="total-area">
      <text class="total-label">合计</text>
      <view class="total-price-wrapper">
        <text class="total-symbol">￥</text>
        <text class="total-price">{{totalPrice}}</text>
      </view>
    </view>
    <button class="checkout-btn" bindtap="checkout">
      <text class="checkout-icon">✓</text>
      <text class="checkout-text">去结算</text>
      <text class="checkout-count" wx:if="{{selectedCount > 0}}">({{selectedCount}})</text>
    </button>
  </view>
</view>

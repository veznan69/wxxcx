/* pages/reservationDetail/reservationDetail.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 360rpx;
}

.status-card {
  background: #fff;
  margin: 24rpx 32rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.status-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.status-tag.unpaid { background: #FFF3E0; color: #FF6600; }
.status-tag.paid { background: #E8F5E9; color: #4CAF50; }
.status-tag.completed { background: #E3F2FD; color: #2196F3; }
.status-tag.cancelled { background: #FFEBEE; color: #F44336; }

.order-no {
  font-size: 24rpx;
  color: #999;
}

.section {
  background: #fff;
  margin: 0 32rpx 24rpx;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.course-info {
  display: flex;
  gap: 20rpx;
}

.course-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.course-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.course-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
}

.course-price {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.course-price .price {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6600;
}

.course-price .unit {
  font-size: 24rpx;
  color: #999;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-item.total {
  border-top: 2rpx solid #eee;
  margin-top: 20rpx;
  padding-top: 24rpx;
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
  min-width: 180rpx;
  flex-shrink: 0;
}

.label.required::before {
  content: '*';
  color: #FF6600;
  margin-right: 4rpx;
}

.value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.value.empty {
  color: #999;
}

.input-value {
  flex: 1;
  height: 60rpx;
  background: #f7f7f7;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #333;
}

.textarea-value {
  flex: 1;
  min-height: 120rpx;
  background: #f7f7f7;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-value {
  flex: 1;
  height: 60rpx;
  background: #f7f7f7;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  position: relative;
}

.picker-value::after {
  content: '';
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  border: 6rpx solid transparent;
  border-top-color: #999;
}

.info-item.total .price {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF6600;
}

.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.agreement-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  column-gap: 8rpx;
  row-gap: 6rpx;
  margin-bottom: 16rpx;
}

.agreement-group {
  display: flex;
  align-items: center;
}

.agreement-label {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
}

.agreement-link {
  font-size: 24rpx;
  color: #FF6600;
}

.action-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.secondary-actions {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
}

.pay-btn,
.edit-btn,
.cancel-btn,
.save-btn {
  height: 76rpx;
  border-radius: 38rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0;
  padding: 0 24rpx;
  line-height: 1;
}

.pay-btn {
  width: 420rpx;
  background: linear-gradient(135deg, #FF6600 0%, #FF8533 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 102, 0, 0.3);
}

.edit-btn,
.cancel-btn {
  min-width: 220rpx;
  background: #f7f7f7;
  color: #666;
}

.save-btn {
  min-width: 220rpx;
  background: linear-gradient(135deg, #FF6600 0%, #FF8533 100%);
  color: #fff;
}

.single-btn {
  width: 420rpx;
}

.pay-btn::after,
.edit-btn::after,
.cancel-btn::after,
.save-btn::after {
  border: none;
}
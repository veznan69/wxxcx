<!-- pages/user/user.wxml -->
<view class="user-container">
  <view class="user-card" bindtap="handleLogin">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/avatar.png'}}" mode="aspectFill"></image>
      <view class="user-detail">
        <text class="nickname">{{userInfo.nickName || '游客用户'}}</text>
        <text class="tips">点击下方退出登录即可退出当前账号</text>
      </view>
      <view class="edit-icon" catchtap="showEditPopup" wx:if="{{isLoggedIn}}">✏️</view>
    </view>
  </view>

  <view class="edit-popup" wx:if="{{showEdit}}">
    <view class="popup-mask" bindtap="hideEditPopup"></view>
    <view class="popup-container">
      <view class="popup-title">编辑个人资料</view>
      <button class="avatar-wrapper" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="edit-avatar" src="{{tempAvatarUrl || userInfo.avatarUrl || '/images/avatar.png'}}" mode="aspectFill"></image>
        <text class="avatar-tip">点击更换头像</text>
      </button>
      <input
        type="nickname"
        class="nickname-input"
        placeholder="请输入昵称"
        bindinput="onNicknameInput"
        value="{{tempNickName}}"
      />
      <view class="popup-buttons">
        <button class="cancel-btn" bindtap="hideEditPopup">取消</button>
        <button class="save-btn" bindtap="saveUserInfo">保存</button>
      </view>
    </view>
  </view>

  <view class="order-status">
    <view class="status-item" bindtap="onTapPendingPay">
      <text class="num">{{pendingPayCount}}</text>
      <text>待付款</text>
    </view>
    <view class="status-item" bindtap="onTapPendingShip">
      <text class="num">{{pendingShipCount}}</text>
      <text>待发货</text>
    </view>
    <view class="status-item" bindtap="onTapPendingReceive">
      <text class="num">{{pendingReceiveCount}}</text>
      <text>待收货</text>
    </view>
    <view class="status-item">
      <text class="num">0</text>
      <text>待评价</text>
    </view>
  </view>

  <view class="menu-list">
    <view
      class="menu-item"
      wx:for="{{roleMenus}}"
      wx:key="name"
      bindtap="{{item.tap}}"
      style="animation: fadeInUp 0.4s ease forwards; animation-delay: {{index * 0.08}}s; opacity: 0;"
    >
      <view class="menu-left">
        <view class="menu-icon-wrapper">
          <text class="icon">{{item.icon}}</text>
          <view class="red-dot" wx:if="{{hasUnreadMessage && item.name === '我的消息'}}"></view>
        </view>
        <text>{{item.name}}</text>
      </view>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="feedback-modal" wx:if="{{showFeedback}}" catchtap="hideFeedbackDialog">
    <view class="feedback-dialog" catchtap="stopPropagation">
      <view class="dialog-header">
        <text>意见反馈</text>
        <text class="dialog-close" bindtap="hideFeedbackDialog">✕</text>
      </view>
      <view class="dialog-body">
        <textarea
          placeholder="请输入您的建议或反馈（必填）"
          maxlength="500"
          bindinput="onFeedbackContentInput"
          value="{{feedbackContent}}"
          auto-height
        />
        <input
          placeholder="联系方式（选填，手机号/微信/邮箱均可）"
          bindinput="onFeedbackContactInput"
          value="{{feedbackContact}}"
        />
        <button class="submit-btn" bindtap="submitFeedback" loading="{{submitting}}" disabled="{{!feedbackContent}}">
          提交反馈
        </button>
      </view>
    </view>
  </view>
</view>

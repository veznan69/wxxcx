/* pages/user/user.wxss */
.user-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  /* padding: 30rpx 24rpx; */
  padding-top: 0rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-bottom: 30rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #ff9944, #ff6600);
  border-radius: 32rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 102, 0, 0.2);
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid #fff;
  margin-right: 30rpx;
  background-color: #fff;
}

.user-detail {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.tips {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 订单状态栏（四个小卡片） */
.order-status {
  display: flex;
  justify-content: space-around;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx 0;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.status-item {
  text-align: center;
  flex: 1;
}

.status-item .num {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6600;
  margin-bottom: 8rpx;
}

.status-item text:last-child {
  font-size: 26rpx;
  color: #666;
}

/* 功能菜单卡片列表 */
.menu-list {
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.2s;
}

.menu-item:active {
  background-color: #f9f9f9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon-wrapper {
  position: relative;
  margin-right: 24rpx;
  width: 48rpx;
  display: flex;
  justify-content: center;
}

.menu-left .icon {
  font-size: 40rpx;
}

.red-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #ff4d4f;
  border-radius: 50%;
  border: 2rpx solid #fff;
}

.menu-left text:last-child {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 新增 */
/* 编辑图标：放在卡片右上角 */
.user-info {
  position: relative;  /* 让编辑图标相对于 .user-info 定位 */
}

.edit-icon {
  position: absolute;
  top: -10rpx;
  right: 0;
  font-size: 44rpx;
  padding: 10rpx;
  color: rgba(255, 255, 255, 0.9);
  background-color: rgba(0, 0, 0, 0.2);
  border-radius: 50%;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

/* 编辑弹窗样式 */
.edit-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}
.popup-mask {
  position: absolute;
  width: 100%;
  height: 100%;
  background-color: rgba(0,0,0,0.5);
}
.popup-container {
  position: absolute;
  bottom: 0;
  width: 100%;
  background-color: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx;
  box-sizing: border-box;
}
.popup-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}
.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  margin-bottom: 40rpx;
}
.edit-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
}
.avatar-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}
.nickname-input {
  border: 1rpx solid #ddd;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 32rpx;
  margin-bottom: 40rpx;
}
.popup-buttons {
  display: flex;
  justify-content: space-between;
}
.cancel-btn, .save-btn {
  flex: 1;
  margin: 0 20rpx;
  border-radius: 50rpx;
  height: 88rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;           /* 移除默认内边距 */
  line-height: 1;       /* 避免行高影响 */
  border: none;         /* 移除默认边框 */
}
.cancel-btn::after, .save-btn::after {
  border: none;         /* 移除 button 的伪元素边框 */
}
.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
}
.save-btn {
  background-color: #ff6600;
  color: #fff;
}

/* 反馈弹窗样式 */
.feedback-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;  /* 高于编辑弹窗 */
}

.feedback-dialog {
  width: 620rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  animation: fadeIn 0.2s;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  font-size: 34rpx;
  font-weight: 500;
}

.dialog-close {
  font-size: 40rpx;
  color: #999;
  padding: 0 10rpx;
}

.dialog-body {
  padding: 30rpx;
}

.dialog-body textarea {
  width: 100%;
  min-height: 180rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.dialog-body input {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}

.submit-btn {
  background: #ff6600;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.submit-btn[disabled] {
  background: #ccc;
  color: #999;
}

@keyframes fadeIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

/* 渐显动画：从透明、下方位移到原位 */
@keyframes fadeInUp {
  0% {
    opacity: 0;
    transform: translateY(20rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}
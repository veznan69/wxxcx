.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}
.address-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.contact {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}
.name {
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 24rpx;
}
.phone {
  color: #666;
}
.detail {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 12rpx;
}
.tag-wrap {
  margin-top: 8rpx;
}
.default-tag {
  background: #FF6600;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}
.action-btn {
  margin-left: 40rpx;
  color: #FF6600;
  font-size: 28rpx;
}
.add-btn {
  background: #FF6600;
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 48rpx;
  margin-top: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
}
.empty-tip {
  text-align: center;
  color: #999;
  padding: 100rpx 0;
}
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}
.modal-content {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  z-index: 101;
  animation: slideUp 0.3s;
}
.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}
.form-item {
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 20rpx;
}
.form-item input {
  width: 100%;
  font-size: 30rpx;
}
.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.arrow {
  font-size: 40rpx;
  color: #999;
}
.checkbox-item {
  display: flex;
  align-items: center;
  border-bottom: none;
}
.checkbox-item checkbox {
  margin-right: 16rpx;
}
.modal-btns {
  display: flex;
  margin-top: 40rpx;
}
.cancel-btn, .confirm-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
}
.cancel-btn {
  background: #f5f5f5;
  color: #666;
  margin-right: 20rpx;
}
.confirm-btn {
  background: #FF6600;
  color: #fff;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.status {
  color: #ff6600;
  font-size: 28rpx;
  font-weight: 600;
}

.time, .id {
  color: #999;
  font-size: 24rpx;
}

.title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.item {
  display: flex;
  margin-bottom: 16rpx;
}

.item:last-child {
  margin-bottom: 0;
}

.img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.meta {
  font-size: 24rpx;
  color: #666;
}

.total {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: right;
  font-size: 28rpx;
  font-weight: 600;
}

.input {
  height: 80rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
}

.hint {
  display: block;
  margin-top: 12rpx;
  color: #999;
  font-size: 24rpx;
}

.footer {
  position: sticky;
  bottom: 20rpx;
}

.btn {
  background: #ff6600;
  color: #fff;
  border-radius: 999rpx;
}

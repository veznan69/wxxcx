/* pages/coupon/coupon.wxss */
.coupon-page {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

/* 分类标签栏 */
.coupon-tabs {
  display: flex;
  background: #fff;
  border-radius: 50rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}
.tab-item.active {
  background: #ff6600;
  color: #fff;
  font-weight: bold;
}

/* 优惠券列表 */
.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding-top: 200rpx;
}
.empty-icon {
  font-size: 120rpx;
  opacity: 0.6;
  display: block;
  margin-bottom: 30rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 优惠券卡片 */
.coupon-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
/* 已使用样式 */
.coupon-card.used {
  opacity: 0.6;
  background: #f5f5f5;
}

/* 左侧金额区域 */
.coupon-left {
  width: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 2rpx dashed #ffcc99;
  margin-right: 20rpx;
}
.coupon-price {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff6600;
  line-height: 1.2;
}
.coupon-condition {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 右侧信息区域 */
.coupon-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.coupon-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}
.coupon-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}
.coupon-time {
  font-size: 24rpx;
  color: #999;
}

/* 已使用标签 */
.coupon-status {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  background: #999;
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}
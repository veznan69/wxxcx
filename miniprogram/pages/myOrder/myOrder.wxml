<view class="order-container">
  <!-- 顶部标签 -->
  <view class="tab-bar">
    <view class="tab {{tabActive === 0 ? 'active' : ''}}" bindtap="changeTab" data-index="0">采摘预约</view>
    <view class="tab {{tabActive === 1 ? 'active' : ''}}" bindtap="changeTab" data-index="1">研学预约</view>
  </view>

  <!-- 预约列表 -->
  <view class="order-list">
    <!-- 空状态 -->
    <view wx:if="{{orderList.length === 0}}" class="empty-box">
      <text class="empty-text">暂无预约记录</text>
    </view>

    <!-- 预约卡片 -->
    <view class="card" wx:for="{{orderList}}" wx:key="id">
      <view class="card-type">{{item.type === 0 ? '采摘预约' : '研学预约'}}</view>
      <view class="card-title">{{item.title}}</view>
      <view class="card-info">人数：{{item.people || 1}} 人</view>
      <view class="card-info">预约日期：{{item.date || '待安排'}}</view>
      <view class="card-status">{{item.status}}</view>
    </view>
  </view>
</view>
/* pages/pointRules/pointRules.wxss */
.rules-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* 头部 */
.rules-header {
  background: linear-gradient(135deg, #ffd666, #ff9c00);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 20rpx rgba(255, 156, 0, 0.3);
}

.header-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

/* 规则区块 */
.rule-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

/* 规则列表 */
.rule-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.rule-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rule-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.rule-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.rule-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.rule-points {
  font-size: 26rpx;
  color: #ff9c00;
  font-weight: bold;
}

.rule-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  padding-left: 52rpx;
}

/* 注意事项 */
.notice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notice-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  padding-left: 8rpx;
}

/* 联系客服 */
.contact-box {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.contact-text {
  font-size: 28rpx;
  color: #666;
}

.contact-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: #ff9c00;
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 26rpx;
}

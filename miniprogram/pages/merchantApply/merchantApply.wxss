/* pages/merchantApply/merchantApply.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(145deg, #f8f9fc 0%, #eef1f6 100%);
  padding: 32rpx 32rpx 60rpx;
  box-sizing: border-box;
}

/* 页面主标题 */
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1a1a1a;
  text-align: center;
  margin: 30rpx 0 50rpx;
  letter-spacing: 2rpx;
  position: relative;
}
.title::after {
  content: '';
  display: block;
  width: 80rpx;
  height: 6rpx;
  background: #FF6600;
  border-radius: 6rpx;
  margin: 16rpx auto 0;
}

/* 表单卡片 */
.form-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.03);
  transition: all 0.2s;
}
.form-item:active {
  box-shadow: 0 4rpx 16rpx rgba(255,102,0,0.08);
}

.label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
  position: relative;
  padding-left: 16rpx;
}
.label::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: #FF6600;
  border-radius: 6rpx;
}

/* 输入框 */
input, textarea {
  width: 100%;
  background: #f8fafd;
  border-radius: 16rpx;
  padding: 24rpx 24rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border 0.2s, background 0.2s;
  line-height: 1.5;           /* 新增 */
  min-height: 88rpx;          /* 确保 input 最小高度 */
}
input:focus, textarea:focus {
  border-color: #FF6600;
  background: #fff;
}
input::placeholder, textarea::placeholder {
  color: #aaa;
  font-size: 28rpx;
}

textarea {
  min-height: 180rpx;
}

/* 营业执照上传区域 */
.upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 140rpx;
  background: #f8fafd;
  border: 2rpx dashed #ccc;
  border-radius: 20rpx;
  color: #666;
  font-size: 28rpx;
  transition: all 0.2s;
}
.upload-btn:active {
  border-color: #FF6600;
  background: #fff9f5;
  color: #FF6600;
}

/* 图片预览列表 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 24rpx;
}
.image-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #eee;
  background: #f5f5f5;
}

/* 提交按钮（确保阴影） */
.submit-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6600, #ff8c42);
  color: #fff;
  border-radius: 60rpx;
  font-size: 36rpx;
  font-weight: bold;
  margin-top: 40rpx;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(255,102,0,0.3);  /* 增强阴影 */
  transition: all 0.2s;
}
.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(255,102,0,0.4);
}
.submit-btn[disabled] {
  background: #ccc;
  box-shadow: none;
  color: #999;
}

/* 查看状态按钮（增加阴影） */
.status-btn {
  width: 100%;
  height: 90rpx;
  background: #fff;
  color: #FF6600;
  border: 2rpx solid #FF6600;
  border-radius: 60rpx;
  font-size: 32rpx;
  margin-top: 30rpx;          /* 加大间距 */
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);  /* 轻微阴影增强立体感 */
  transition: all 0.2s;
}
.status-btn:active {
  background: #fff9f5;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}
.image-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
}
.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #eee;
}
.image-item .image {
  width: 100%;
  height: 100%;
}
.delete-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 12rpx 0 12rpx;
}

/* 状态提示 */
.status-tip {
  margin-top: 30rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 20rpx;
}
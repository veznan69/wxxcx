.monitor-page {
  background-color: #000;
  min-height: 100vh;
}

.video-container {
  width: 100%;
  height: 500rpx;
  position: relative;
}

.video-placeholder-wrap {
  width: 100%;
  height: 100%;
  position: relative;
}

.video-placeholder {
  width: 100%;
  height: 100%;
}

.loading-text {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 24rpx;
  text-align: center;
  color: #fff;
  font-size: 28rpx;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.45);
}

.monitor-video {
  width: 100%;
  height: 100%;
}

.tree-info-card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 0 20rpx 24rpx;
  margin-top: 20rpx;
  align-items: flex-start;
}

.action-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  width: 100%;
  background: #ff6600;
  color: #fff;
  border-radius: 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  font-weight: 500;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.action-btn-camera {
  flex: 1;
}

.action-btn-secondary {
  background: #ffa15f;
}

.action-btn::after {
  border: none;
}

/* pages/detail/detail.wxss */
.detail-page {
  background-color: #fff;
  padding-bottom: 180rpx;
}

/* 轮播图 */
.swiper {
  width: 100%;
  height: 750rpx;
}
.swiper-image {
  width: 100%;
  height: 100%;
}

/* 商品信息 */
.goods-info {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}
.price {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff6600;
  margin-right: 20rpx;
}
.sales {
  font-size: 26rpx;
  color: #999;
}
.name {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}
.desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
}

/* 规格与数量  */
.spec-quantity {
  background: #fff;
  padding: 0 30rpx;
  margin: 20rpx 0;
}


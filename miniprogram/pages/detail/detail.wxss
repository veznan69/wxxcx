}
.arrow {
  color: #ccc;
  font-size: 32rpx;
} */
.quantity {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: none;
}
.stepper {
  display: flex;
  align-items: center;
}
.stepper-btn {
  width: 56rpx;
  height: 56rpx;
  background: #f5f5f5;
  border-radius: 28rpx;
  text-align: center;
  line-height: 56rpx;
  font-size: 40rpx;
  font-weight: bold;
  color: #666;
}
.stepper-num {
  width: 80rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333;
}

/* 商品详情描述  */
.detail-desc {
  padding: 30rpx;
  background: #fff;
  margin-top: 20rpx;
  margin-bottom: 40rpx;
}
.detail-desc .title {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #ff6600;
}
.detail-desc rich-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.bottom-bar > view {
  flex: 1;
  text-align: center;
  line-height: 80rpx;
  border-radius: 60rpx;
  font-size: 30rpx;
  margin: 0 10rpx;
}
.contact {
  background: #f5f5f5;
  color: #666;
}
.cart {
  background: #ffaa44;
  color: #fff;
}
.buy {
  background: #ff6600;
  color: #fff;
}


.spec-popup {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}
.popup-content {
  background: #fff;
  width: 100%;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 30rpx;
  animation: slideUp 0.3s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.popup-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}
.spec-list {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 40rpx;
}
.spec-option {
  background: #f5f5f5;
  padding: 16rpx 30rpx;
  border-radius: 60rpx;
  margin: 0 20rpx 20rpx 0;
  font-size: 28rpx;
  color: #333;
}
.close-btn {
  background: #ff6600;
  color: #fff;
  border-radius: 60rpx;
  width: 80%;
  margin: 0 auto;
}
  
  .section-title {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 30rpx;
  }
  
  .title-icon {
    font-size: 36rpx;
    margin-right: 12rpx;
  }
  
  .title-text {
    font-size: 30rpx;
    font-weight: 600;
    color: #FF6600;
  }
  
  .qrcode-wrapper {
    display: flex;
    justify-content: center;
    padding: 20rpx;
    background: #fafafa;
    border-radius: 20rpx;
  }
  
  .trace-qrcode {
    width: 320rpx;
    height: 320rpx;
  }
  
  .scan-tip {
    text-align: center;
    font-size: 24rpx;
    color: #999;
    margin-top: 20rpx;
  }

  .qrcode-section {
    background: #fff;
    margin: 30rpx;
    padding: 30rpx;
    border-radius: 24rpx;
    box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  }
  .qrcode-label {
    font-size: 30rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 20rpx;
  }
  .qrcode-box {
    display: flex;
    justify-content: center;
    align-items: center;
    background: #f8f8f8;
    border-radius: 16rpx;
    padding: 20rpx;
    min-height: 300rpx;
  }
  .qrcode-img {
    width: 280rpx;
    height: 280rpx;
  }
  .qrcode-loading {
    color: #999;
    font-size: 28rpx;
  }
  .qrcode-actions {
    display: flex;
    justify-content: space-around;
    margin-top: 20rpx;
  }
  .action-btn {
    flex: 1;
    margin: 0 10rpx;
    color: #ff6600;
    border-color: #ff6600;
  }
  .qrcode-tip {
    display: block;
    margin-top: 20rpx;
    font-size: 24rpx;
    color: #999;
    text-align: center;
  }

  /* 款式弹窗 */
.sku-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}
.popup-content {
  background: #fff;
  width: 100%;
  border-radius: 40rpx 40rpx 0 0;
  padding: 30rpx;
  animation: slideUp 0.3s ease;
}
.popup-header {
  display: flex;
  margin-bottom: 30rpx;
}
.popup-goods-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
}
.popup-goods-info {
  flex: 1;
}
.popup-goods-info .price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6600;
  display: block;
}
.popup-goods-info .stock {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin: 10rpx 0;
}
.popup-goods-info .selected-sku {
  font-size: 26rpx;
  color: #666;
}
.close-icon {
  font-size: 48rpx;
  color: #999;
  padding: 0 10rpx;
}
.sku-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.sku-list {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 30rpx;
}
.sku-item {
  width: 200rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  text-align: center;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  padding: 16rpx 0;
  transition: all 0.2s;
}
.sku-item.active {
  border-color: #ff6600;
  background: #fff9f0;
}
.sku-item image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
}
.sku-item text {
  display: block;
  font-size: 26rpx;
  color: #333;
}
.sku-price {
  color: #ff6600;
  font-weight: bold;
  margin-top: 6rpx;
}
.popup-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.quantity-stepper {
  display: flex;
  align-items: center;
}
.quantity-stepper text {
  margin-right: 20rpx;
}
.confirm-btn {
  background: #ff6600;
  color: #fff;
  border-radius: 40rpx;
  padding: 16rpx 60rpx;
  font-size: 30rpx;
  border: none;
}
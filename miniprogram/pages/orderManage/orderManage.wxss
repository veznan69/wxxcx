.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
}

.tab-item.active {
  color: #ff6600;
  border-bottom: 4rpx solid #ff6600;
  font-weight: 600;
}

.list {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.status {
  font-size: 26rpx;
  font-weight: 600;
}

.status.pending {
  color: #ff6600;
}

.status.shipped {
  color: #2196f3;
}

.status.completed {
  color: #4caf50;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.item {
  display: flex;
  margin-bottom: 16rpx;
}

.item:last-child {
  margin-bottom: 0;
}

.img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.meta {
  font-size: 24rpx;
  color: #666;
}

.card-footer {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.total {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.ship-btn {
  margin: 0;
  background: #ff6600;
  color: #fff;
  border-radius: 999rpx;
  font-size: 24rpx;
  padding: 0 24rpx;
}

.empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 160rpx 0;
}

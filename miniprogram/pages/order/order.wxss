/* 页面整体 */
.order-page {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 地址卡片 */
.address-card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.address-left {
  flex: 1;
}
.address-left .name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}
.address-left .phone {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}
.address-left .detail {
  font-size: 26rpx;
  color: #999;
  display: block;
}
.arrow {
  font-size: 32rpx;
  color: #999;
}

/* 商品卡片 */
.goods-card {
  background: #fff;
  margin: 20rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.goods-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.goods-item:last-child {
  border-bottom: none;
}
.goods-item image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}
.info {
  flex: 1;
}
.info .name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}
.info .num {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 6rpx;
}
.info .price {
  font-size: 26rpx;
  color: #ff6600;
  font-weight: bold;
}

/* 实付金额卡片 */
.total-card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.total-card text {
  font-size: 30rpx;
  color: #333;
}
.total-card .price {
  font-size: 36rpx;
  color: #ff6600;
  font-weight: bold;
}

/* 底部按钮容器 */
.order-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 按钮样式 */
.submit-btn {
  background: linear-gradient(135deg, #ff8c42, #ff6600);
  color: #fff;
  border-radius: 56rpx;
  height: 88rpx;
  width: 100%;
  display: flex;
  align-items: center;     
  justify-content: center; 
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 102, 0, 0.3);
}

.submit-btn::after {
  border: none;  
}

.submit-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}
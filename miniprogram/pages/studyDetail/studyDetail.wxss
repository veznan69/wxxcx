/* pages/studyDetail/studyDetail.wxss */
.detail-page {
  background: #f8f9fa;
  padding-bottom: 160rpx;
}

/* 头部海报 */
.header-poster {
  position: relative;
  width: 100%;
  height: 400rpx;
}
.poster-bg {
  width: 100%;
  height: 100%;
  filter: brightness(0.6);
}
.poster-overlay {
  position: absolute;
  bottom: 30rpx;
  left: 30rpx;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}
.course-name {
  font-size: 44rpx;
  font-weight: bold;
  display: block;
}
.course-sub {
  font-size: 28rpx;
  display: block;
  margin-top: 8rpx;
  opacity: 0.9;
}
.price-tag {
  display: inline-block;
  margin-top: 16rpx;
  background: #ff6600;
  padding: 8rpx 24rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 海报全图展示 */
.poster-full {
  margin: 30rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.full-poster {
  width: 100%;
  display: block;
  height: auto;            /* 确保高度自适应 */
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.05);
}
.price-info {
  display: flex;
  align-items: baseline;
}
.price-info .label {
  font-size: 28rpx;
  color: #666;
  margin-right: 10rpx;
}
.price-info .price {
  font-size: 44rpx;
  font-weight: bold;
  color: #ff6600;
}
.signup-btn {
  background: #ff6600;
  color: #fff;
  border-radius: 60rpx;
  padding: 16rpx 50rpx;
  font-size: 30rpx;
  border: none;
}
.signup-btn::after {
  border: none;
}
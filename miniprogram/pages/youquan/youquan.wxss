/* pages/youquan/youquan.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
  padding-bottom: 140rpx; /* 为FAB留出空间 */
}

/* 右下角悬浮按钮（FAB） */
.fab-button {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #FF6600 0%, #FF8533 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(255, 102, 0, 0.4);
  z-index: 1000;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 8rpx 20rpx rgba(255, 102, 0, 0.4);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 8rpx 30rpx rgba(255, 102, 0, 0.6);
  }
}

.fab-icon {
  font-size: 80rpx;
  font-weight: 300;
  color: #ffffff;
  line-height: 1;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #cccccc;
}

/* 帖子列表 */
.posts-list {
  padding: 20rpx;
}

/* 帖子项 */
.post-item {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 帖子头部 */
.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.post-time {
  font-size: 24rpx;
  color: #999999;
}

/* 帖子内容 */
.post-content {
  margin-bottom: 20rpx;
}

.post-title {
  display: block;
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.post-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

/* 帖子图片 */
.post-images {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx -10rpx -10rpx;
}

.post-image {
  width: 200rpx;
  height: 200rpx;
  margin: 10rpx;
  border-radius: 10rpx;
  background-color: #f5f5f5;
}

/* 帖子操作 */
.post-actions {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-item {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
}

.action-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.action-count {
  font-size: 26rpx;
  color: #999999;
}

/* 点赞按钮 */
.like-button {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 30rpx;
  background-color: #f5f5f5;
  transition: all 0.3s;
}

.like-button.liked {
  background-color: #FFE5E5;
}

.like-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
  transition: all 0.3s;
}

.like-button.liked .like-icon {
  color: #FF6600;
  transform: scale(1.1);
}

.like-count {
  font-size: 26rpx;
  color: #666666;
}

.like-button.liked .like-count {
  color: #FF6600;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999999;
  font-size: 28rpx;
}

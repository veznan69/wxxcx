/* pages/courseReservation/courseReservation.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 220rpx;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #FF6600 0%, #FF8533 100%);
  padding: 40rpx 32rpx 48rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 课程信息卡片 */
.course-card {
  background: #fff;
  margin: 24rpx 32rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.course-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.course-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.course-price {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.price {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6600;
}

.unit {
  font-size: 24rpx;
  color: #999;
}

/* 表单区域 */
.form-section {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
  position: relative;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item.required::before {
  content: '*';
  position: absolute;
  left: -16rpx;
  top: 8rpx;
  color: #FF6600;
  font-size: 28rpx;
  font-weight: bold;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #f7f7f7;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f7f7f7;
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.picker {
  height: 80rpx;
  background: #f7f7f7;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  position: relative;
}

.picker::after {
  content: '';
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  border: 8rpx solid transparent;
  border-top-color: #999;
}

.picker.placeholder {
  color: #999;
}

/* 底部操作栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 0 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.footer-center {
  height: 112rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.submit-btn {
  width: 420rpx;
  height: 80rpx;
  margin: 0;
  padding: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(135deg, #FF6600 0%, #FF8533 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  line-height: 1;
  box-shadow: 0 8rpx 24rpx rgba(255, 102, 0, 0.3);
}

.submit-btn::after {
  border: none;
}

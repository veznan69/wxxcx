.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 20rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.title {
  font-size: 30rpx;
  color: #222;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.row:last-child {
  margin-bottom: 0;
}

.label {
  color: #666;
  font-size: 26rpx;
}

.value {
  color: #222;
  font-size: 26rpx;
  max-width: 65%;
  text-align: right;
  word-break: break-all;
}

.status {
  color: #ff6600;
  font-weight: 600;
}

.trace-item {
  display: flex;
  position: relative;
  padding-bottom: 18rpx;
}

.trace-item:last-child {
  padding-bottom: 0;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #c9c9c9;
  margin-top: 10rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.trace-item.latest .dot {
  background: #ff6600;
}

.content {
  display: flex;
  flex-direction: column;
}

.time {
  color: #999;
  font-size: 22rpx;
  margin-bottom: 4rpx;
}

.text {
  color: #333;
  font-size: 26rpx;
  line-height: 1.5;
}

.trace-item.latest .text {
  color: #ff6600;
  font-weight: 600;
}

.empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 140rpx 0;
}

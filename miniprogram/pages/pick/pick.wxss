.pick {
  background: #fff;
  min-height: 100vh;
}
.banner {
  width: 100%;
}
.form {
  padding: 30rpx;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: #ff6600;
}
.field {
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}
.field text {
  width: 140rpx;
  font-size: 30rpx;
}
.field input, .field picker {
  flex: 1;
  border-bottom: 1rpx solid #eee;
  padding: 20rpx 0;
}
button {
  margin-top: 40rpx;
  background-color: #ff6600;
  color: #fff;
}
.tips {
  padding: 30rpx;
  background: #fff9f0;
  margin: 30rpx;
  border-radius: 16rpx;
  color: #b45f1b;
  font-size: 26rpx;
}

/* 新增容器和背景 */
.pick-container {
  position: relative;
  min-height: 100vh;
}

.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.pick {
  position: relative;
  z-index: 2;
  background: transparent;
  min-height: 100vh;
  /* =========【卡片整体向上偏移】========= */
  padding-top: 60rpx;
}

/* 让表单卡片有半透明白底，文字可读 */
.form {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(8rpx);
  border-radius: 24rpx;
  margin: 0 30rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.1);
}

/* 提示卡片同样半透明 + 上移 */
.tips {
  background: rgba(255, 249, 240, 0.9);
  backdrop-filter: blur(4rpx);
  border-radius: 16rpx;
  margin: 20rpx 30rpx;
}

.banner {
  width: 100%;
}
/* pages/publishPost/publishPost.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 表单区块 */
.form-section {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.section-title.required::before {
  content: '*';
  color: #ff4d4f;
  margin-right: 8rpx;
}

.section-hint {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 10rpx;
}

/* 图片列表 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx -10rpx -10rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin: 10rpx;
}

.image-preview {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
  background-color: #f5f5f5;
}

.image-delete {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 30rpx;
  color: #ffffff;
  line-height: 1;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  margin: 10rpx;
  border: 2rpx dashed #cccccc;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #fafafa;
}

.add-icon {
  font-size: 60rpx;
  color: #cccccc;
  line-height: 1;
  margin-bottom: 10rpx;
}

.add-text {
  font-size: 24rpx;
  color: #999999;
}

/* 输入框 */
.input-field {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333333;
}

.textarea-field {
  width: 100%;
  min-height: 300rpx;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  box-sizing: border-box;
}

/* 字数统计 */
.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 10rpx;
}

/* 提交按钮 */
.submit-btn {
  position: fixed;
  bottom: 20rpx;
  left: 20rpx;
  right: 20rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #ff6600, #ff8533);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 15rpx rgba(255, 102, 0, 0.3);
}

.submit-btn text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
}
